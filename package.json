{
  "name": "garmin-codemode-mcp",
  "version": "1.0.0",
  "description": "Garmin Connect MCP server using Cloudflare Code Mode",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "auth": "tsx cli/auth.ts",
    "auth:verify": "tsx cli/auth.ts --verify",
    "lint:quick": "oxlint -c .oxlintrc.json src/",
    "lint": "oxlint -c .oxlintrc.json src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "knip": "knip",
    "check": "tsc --noEmit && oxlint -c .oxlintrc.json src/ && prettier --check 'src/**/*.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@cloudflare/codemode": "^0.3.3",
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.8.5",
    "ai": "^6.0.138",
    "oauth-1.0a": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.2",
    "knip": "^6.3.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.77.0"
  }
}
